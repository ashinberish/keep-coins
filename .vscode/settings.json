{
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/uv.lock": true,
    "**/pnpm-lock.yaml": true,
    "**/.vscode": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.organizeImports": "always"
  }
}
